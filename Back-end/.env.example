PORT=4000

# --- Database ---
# Either a single DATABASE_URL (Neon/Render, connects over SSL)...
# DATABASE_URL=postgres://user:pass@host/db?sslmode=require
# ...or the discrete vars below (local / docker-compose):
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=replaygear

# --- Auth (set a strong secret in production!) ---
JWT_ACCESS_SECRET=dev-access-secret-change-me
ACCESS_TTL_SECONDS=900
REFRESH_TTL_DAYS=7

# Default admin, seeded on first boot if missing
ADMIN_EMAIL=admin@replaygear.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=Store Admin

# --- Email (order confirmations) ---
# Production (Render/PaaS block outbound SMTP): use Brevo's HTTPS API instead.
# Set BREVO_API_KEY and it takes priority over SMTP.
# BREVO_API_KEY=xkeysib-...
#
# Local dev (Mailpit over SMTP) — used when BREVO_API_KEY is NOT set:
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
#
# MAIL_FROM must be a VERIFIED sender in Brevo (used by both paths).
MAIL_FROM=ReplayGear <no-reply@replaygear.com>
