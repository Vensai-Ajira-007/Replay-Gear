PORT=4000

# --- Database ---
# Either a single DATABASE_URL (Neon/Render, connects over SSL)...
# DATABASE_URL=postgres://user:pass@host/db?sslmode=require
# ...or the discrete vars below (local / docker-compose):
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=replaygear

# --- Auth (set a strong secret in production!) ---
JWT_ACCESS_SECRET=dev-access-secret-change-me
ACCESS_TTL_SECONDS=900
REFRESH_TTL_DAYS=7

# Default admin, seeded on first boot if missing
ADMIN_EMAIL=admin@replaygear.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=Store Admin

# --- Email (order confirmations) ---
# Local (Mailpit): host=localhost port=1025 secure=false, no user/pass.
# Production (Brevo): host=smtp-relay.brevo.com port=587 secure=false + user/pass.
# Leave SMTP_HOST unset to disable email (checkout still works).
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
MAIL_FROM=ReplayGear <no-reply@replaygear.com>
